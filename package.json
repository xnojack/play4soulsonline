{
  "name": "four-souls-online",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "npm run scrape",
    "scrape": "npm run build --workspace=packages/scraper && node packages/scraper/dist/index.js",
    "dev": "concurrently \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/client",
    "start": "npm run start --workspace=packages/server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
