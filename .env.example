SERVER_PORT=3001
CLIENT_PORT=3000
MAX_ROOMS=10
# Leave empty to use the nginx reverse proxy (recommended for Docker).
# Only set this if the server is on a different host entirely.
VITE_SERVER_URL=
# Your public-facing URL (e.g. https://foursouls.example.com).
# Used for link embeds (Discord, etc.) and SEO meta tags.
# Leave empty if self-hosting without a fixed domain.
VITE_PUBLIC_URL=
# Restrict CORS to this origin (e.g. https://foursouls.example.com).
# Leave empty to allow same-origin requests only (recommended for reverse-proxy setups).
ALLOWED_ORIGIN=

# Room cleanup timeouts (milliseconds). Rooms are deleted automatically to free slots.
# Lobby: all players disconnect before the game starts (default 5 minutes).
ROOM_TIMEOUT_LOBBY_MS=300000
# Active/in-progress: all players disconnect mid-game (default 30 minutes).
ROOM_TIMEOUT_ACTIVE_MS=1800000
# Ended: game is over (default 10 minutes).
ROOM_TIMEOUT_ENDED_MS=600000
# Created but nobody joined: host closed tab before entering (default 30 minutes).
ROOM_TIMEOUT_CREATED_MS=1800000
